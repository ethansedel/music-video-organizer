# Absolute path as seen by the Docker server.
# TrueNAS SCALE example: /mnt/tank/media/musicvideos
MUSIC_VIDEO_PATH=/mnt/tank/media/musicvideos

# At least eight characters. The web username is: liner-notes
LINER_NOTES_PASSWORD=replace-with-a-long-random-password

# Match a TrueNAS user and group that have read/write access to the dataset.
PUID=1000
PGID=1000

# Optional host port.
LINER_NOTES_PORT=8765

# Use 127.0.0.1 when placing Liner Notes behind an HTTPS reverse proxy.
LINER_NOTES_BIND=0.0.0.0
